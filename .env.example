# RAG-CRM Environment Configuration
# Copy to .env and fill in your LLM provider details

# ──────────────────────────────────────────────
# LLM Provider (OpenAI-compatible API)
# ──────────────────────────────────────────────
# Supported: DeepSeek, OpenAI, Together AI, Groq, OpenRouter, etc.
#
# Examples:
#   DeepSeek:   LLM_API_KEY=sk-xxx   LLM_BASE_URL=https://api.deepseek.com         LLM_MODEL=deepseek-chat
#   OpenAI:     LLM_API_KEY=sk-xxx   LLM_BASE_URL=https://api.openai.com            LLM_MODEL=gpt-4o-mini
#   Together:   LLM_API_KEY=xxx      LLM_BASE_URL=https://api.together.xyz           LLM_MODEL=mistralai/Mixtral-8x7B-Instruct-v0.1
#   Groq:       LLM_API_KEY=gsk-xxx  LLM_BASE_URL=https://api.groq.com/openai        LLM_MODEL=llama3-70b-8192
#   OpenRouter: LLM_API_KEY=sk-xxx   LLM_BASE_URL=https://openrouter.ai/api/v1       LLM_MODEL=openai/gpt-4o-mini

LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# Legacy DeepSeek-specific vars (backward-compatible fallback)
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=

# Local fallback (not required if LLM_API_KEY is set)
# OLLAMA_BASE_URL=http://localhost:11434

# LLM generation settings
# LLM_TEMPERATURE=0.0

# ──────────────────────────────────────────────
# Database (Docker Compose defaults)
# ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://rag_user:rag_pass@localhost:5432/rag_crm
REDIS_URL=redis://localhost:6379/0

# ──────────────────────────────────────────────
# Embedding & Reranker Models
# ──────────────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ──────────────────────────────────────────────
# Auth (JWT)
# ──────────────────────────────────────────────
JWT_SECRET_KEY=

# ──────────────────────────────────────────────
# App Metadata
# ──────────────────────────────────────────────
APP_NAME=RAG-CRM
APP_VERSION=0.1.0
LOG_LEVEL=INFO
