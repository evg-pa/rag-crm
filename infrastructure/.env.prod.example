# Production environment overrides
# Usage: docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d
#
# Copy this file to .env.prod and fill in real values:
#   cp infrastructure/.env.prod.example infrastructure/.env.prod

# ── LLM ──────────────────────────────────────────────────────────
LLM_API_KEY=sk-your-production-key
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# ── Database (override from docker-compose.yml if needed) ─────────
# POSTGRES_USER=rag_user
# POSTGRES_PASSWORD=use-a-strong-random-password-here
# POSTGRES_DB=rag_crm

# ── Security ──────────────────────────────────────────────────────
JWT_SECRET_KEY=generate-a-random-64-char-string-here

# ── CRM ───────────────────────────────────────────────────────────
CRM_ADAPTER=mock
CRM_SYNC_FREQUENCY=manual
CRM_RAG_BRIDGE=false

# ── Logging ───────────────────────────────────────────────────────
LOG_LEVEL=WARNING
